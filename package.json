{
  "name": "@yosbany/sgo-sdk",
  "version": "1.0.4",
  "description": "Librería de funciones de negocio para Gestión Operativa",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yosbany/sgo-sdk.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "public"
  },
  "dependencies": {
    "firebase": "^10.0.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:cjs": "tsc --outDir dist/cjs --module CommonJS",
    "build:esm": "tsc --outDir dist/esm --module ESNext",
    "build": "npm run clean && npm run build:cjs && npm run build:esm"
  }
}
